{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "strict": true,
    "noImplicitAny": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "typeRoots": ["./node_modules/@types"],
    "resolveJsonModule": true,
    "declaration": true,
    "sourceMap": true,
    "inlineSources": true,
    "outDir": "dist",
    "rootDir": ".",
    "skipLibCheck": true
  },
  "exclude": ["node_modules", "cdk.out", "dist"]
}
