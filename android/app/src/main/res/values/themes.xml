<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.MallIQ" parent="android:Theme.Material.NoActionBar">
        <item name="android:statusBarColor">@color/background_night</item>
        <item name="android:navigationBarColor">@color/background_night</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <style name="Theme.MallIQ.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/background_night</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash_glyph</item>
        <item name="windowSplashScreenAnimationDuration">400</item>
        <item name="postSplashScreenTheme">@style/Theme.MallIQ</item>
    </style>
</resources>
