NODE_ENV=production
PORT=4000

MALLIQ_DATA_DIR=/app/server/data
MALLIQ_REQUIRE_AUTH=1
# Generate with: openssl rand -hex 48
MALLIQ_JWT_SECRET=

ALLOWED_ORIGINS=https://do-up.cl,https://www.do-up.cl

MOONSHOT_API_KEY=
MOONSHOT_BASE_URL=https://api.moonshot.ai/v1
CONTRACT_AUTOFILL_MODEL=kimi-k2.5

# Optional fallback (used if MOONSHOT_API_KEY is unset)
# OPENAI_API_KEY=
# OPENAI_BASE_URL=
